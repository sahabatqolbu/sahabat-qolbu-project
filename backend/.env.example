# Server
NODE_ENV=development
PORT=5000

# Database MySQL (Shared Hosting)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_cpanel_user
DB_PASSWORD=your_password
DB_NAME=sahabatqolbu_db

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Email (SMTP - Gmail/Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@sahabatqolbu.com
SMTP_PASS=your-email-password
SMTP_FROM=Sahabat Qolbu <noreply@sahabatqolbu.com>

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Frontend URL (Next.js Static Export)
FRONTEND_URL=https://sahabatqolbu.com

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100