# ===========================================
# Sahabat Qolbu - Environment Configuration
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=5000
ENABLE_LOGS=true
BACKEND_URL=http://localhost:5000

# ===========================================
# Database Configuration (MySQL)
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_cpanel_user
DB_PASSWORD=your_secure_password
DB_NAME=sahabatqolbu_db

# Database Pool Settings
DB_POOL_MAX=5
DB_POOL_IDLE_TIMEOUT=30000

# ===========================================
# JWT Configuration
# ===========================================
# IMPORTANT: Must be at least 32 characters long
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRE=7d

# ===========================================
# Email Configuration (SMTP)
# ===========================================
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@sahabatqolbu.com
SMTP_PASS=your-secure-email-password
SMTP_FROM=Sahabat Qolbu <noreply@sahabatqolbu.com>

# ===========================================
# OTP Configuration
# ===========================================
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5

# ===========================================
# Upload Configuration
# ===========================================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./public/uploads

# ===========================================
# Frontend URLs
# ===========================================
FRONTEND_URL=https://sahabatqolbu.com
DASHBOARD_URL=https://dashboard.sahabatqolbu.com

# ===========================================
# Rate Limiting Configuration
# ===========================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=300
PUBLIC_RATE_LIMIT_WINDOW=15
PUBLIC_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW=15
AUTH_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW=5
OTP_RATE_LIMIT_MAX=3
CREATE_ACCOUNT_RATE_LIMIT_WINDOW=60
CREATE_ACCOUNT_RATE_LIMIT_MAX=5
DISABLE_RATE_LIMIT=false

# ===========================================
# Security Configuration
# ===========================================
# Set to true in production behind HTTPS.
COOKIE_SECURE=false

# Share auth cookie across api.sahabatqolbu.com and dashboard.sahabatqolbu.com.
# Leave empty for localhost/development. Set to .sahabatqolbu.com in production.
COOKIE_DOMAIN=

# Optional SameSite override: lax, strict, or none. Leave empty for automatic secure-aware default.
COOKIE_SAMESITE=

# Use 1 for typical single reverse proxy deployments; set explicitly in production.
TRUST_PROXY=1

# Comma-separated list of IPs for admin access
ADMIN_IP_WHITELIST=

# Allowed CORS origins (comma-separated)
# Include any extra HTTPS origins beyond FRONTEND_URL and DASHBOARD_URL.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Runtime schema patch is emergency-only. Keep false/unset in production.
ENABLE_RUNTIME_SCHEMA_PATCH=false
ALLOW_PROD_RUNTIME_SCHEMA_PATCH=false

# ===========================================
# Monitoring / Smoke / Backup
# ===========================================
SMOKE_BASE_URL=http://localhost:5000
SMOKE_AUTH_COOKIE=
BACKUP_OUTPUT_DIR=backups/uploads
BACKUP_RETENTION_DAYS=14

ERROR_TRACKING_ENABLED=false
ERROR_TRACKING_PROVIDER=log-only

# ===========================================
# Development Settings
# ===========================================
# Set to true to enable debug logging
DEBUG=false

# ===========================================
# IMPORTANT SECURITY NOTES
# ===========================================
# 1. Never commit this file with real credentials
# 2. Use strong passwords (min 32 chars for JWT)
# 3. Rotate secrets regularly
# 4. Enable HTTPS in production
# 5. Set NODE_ENV=production in production
# ===========================================
